# Credenciais SEI (obrigatorio para execucao sem TTY, ex.: nohup/tmux)
# AGIL_SEI_USUARIO=seu_usuario
# AGIL_SEI_SENHA=sua_senha

# Controle de carga do classificador
AGIL_MAX_CHARS_CLASSIFICADOR=250000

# SMTP do relatorio de execucao
AGIL_SMTP_HOST=smtp.gmail.com
AGIL_SMTP_PORT=587
AGIL_EMAIL_USER=watilapm@gmail.com
AGIL_EMAIL_PASSWORD=COLOQUE_AQUI_SUA_APP_PASSWORD
AGIL_EMAIL_FROM=watilapm@gmail.com
AGIL_EMAIL_TO=watilapm@gmail.com

# Opcional: forcar o CSV de entrada
# AGIL_CSV_ENTRADA=/home/wpm/projects/agil/data/entrada/sua_tabela.csv

# Timeouts por documento (opcional)
AGIL_DOC_TIMEOUT_CLICK=8
AGIL_DOC_TIMEOUT_VISUAL=6
AGIL_DOC_TIMEOUT_CONTEUDO=4
AGIL_DOC_TENTATIVAS=5


